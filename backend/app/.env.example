# Название приложения
# Используется в Swagger-документации и в интерфейсе
APP_NAME="AI Sous-Chef API"

# Версия приложения
# Обновляется при каждом релизе
APP_VERSION="0.1.0"

# Режим отладки
# True — включен, False — выключен.
# Включать только для локальной разработки!
DEBUG=True

# Уровень логирования
# Возможные значения (по возрастанию детализации):
# ERROR > WARNING > INFO > DEBUG
# Для разработки рекомендуется DEBUG, для продакшена — INFO или WARNING
LOG_LEVEL="DEBUG"

# URL подключения к PostgreSQL (async SQLAlchemy + asyncpg)
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/ai_sous_chef"
